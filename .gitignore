# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# dữ liệu khách hàng thật (liên hệ, đơn hàng) — không đưa vào git.
# products.json/site.json (nội dung trang) và public/uploads (ảnh/file sản phẩm admin
# đã tải lên) vẫn được commit vì đó là nội dung thật của site, cần có khi deploy.
/src/data/store/contacts.json
/src/data/store/orders.json

# typescript
*.tsbuildinfo
next-env.d.ts

# ảnh tham khảo lưu tạm ở gốc project khi build UI, không phải asset của site
